# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Convex
VITE_CONVEX_URL=https://your-project.convex.cloud

# ScreenshotOne
SCREENSHOTONE_API_KEY=your_key_here

# PageSS (self-hosted screenshot API — alternative to ScreenshotOne)
# Set SCREENSHOT_PROVIDER to "pagess" to use PageSS, or "screenshotone" (default)
SCREENSHOT_PROVIDER=screenshotone
PAGESS_URL=https://your-pagess-instance.vercel.app/api
PAGESS_API_KEY=pss_live_your_key_here

# Resend
RESEND_API_KEY=re_...

# Site URL (for email links)
SITE_URL=http://localhost:5297
