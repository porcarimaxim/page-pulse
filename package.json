{
  "name": "page-pulse",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.6",
  "scripts": {
    "dev": "concurrently -n web,convex -c blue,magenta \"vite dev --port 5297\" \"bunx convex dev\"",
    "dev:web": "vite dev --port 5297",
    "build": "vite build",
    "build:vercel": "bunx convex deploy --cmd 'bun run build' --cmd-url-env-var-name VITE_CONVEX_URL",
    "start": "vite preview --port 5297",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "bunx convex typecheck"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^0.27.14",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.1.14",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-router": "^1.160.2",
    "@tanstack/react-router-devtools": "^1.160.2",
    "@tanstack/react-start": "^1.160.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.31.7",
    "isbot": "^5",
    "lucide-react": "^0.563.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^4.5.1",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "type": "module"
}
